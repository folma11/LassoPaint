{
  "manifestVersion": 5,
  "id": "com.lassopaint.plugin",
  "name": "Lasso Paint",
  "version": "0.15.17",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "27.7.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "lassoPaintPanel",
      "label": {
        "default": "Lasso Paint"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "assets/icons/icon-23.png",
          "scale": [1],
          "theme": ["all"],
          "species": ["toolbar"]
        }
      ],
      "minimumSize": {
        "width": 320,
        "height": 240
      },
      "maximumSize": {
        "width": 1600,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 640
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 640
      }
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "assets/icons/icon-48.png",
      "scale": [1],
      "theme": ["all"],
      "species": ["pluginList"]
    }
  ]
}
