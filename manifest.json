{
  "manifestVersion": 4,
  "id": "com.lassopaint.plugin",
  "name": "Lasso Paint",
  "version": "1.0.1",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "26.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "lassoPaintPanel",
      "label": {
        "default": "Lasso Paint"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "assets/icons/panel-dark.png",
          "scale": [1, 2],
          "theme": ["darkest", "dark", "medium"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "assets/icons/panel-light.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        }
      ],
      "minimumSize": {
        "width": 320,
        "height": 240
      },
      "maximumSize": {
        "width": 1600,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 640
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 640
      }
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "icons/icon-48.png",
      "scale": [1, 2],
      "theme": ["all"],
      "species": ["generic"]
    },
    {
      "width": 48,
      "height": 48,
      "path": "icons/icon-48.png",
      "scale": [1, 2],
      "theme": ["all"],
      "species": ["pluginList"]
    },
    {
      "width": 96,
      "height": 96,
      "path": "icons/icon-96.png",
      "scale": [1],
      "theme": ["all"]
    }
  ]
}
