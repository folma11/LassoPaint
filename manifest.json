{
  "manifestVersion": 5,
  "id": "com.lassopaint.plugin",
  "name": "Lasso Paint",
  "version": "0.6.3",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "27.7.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "lassoPaintPanel",
      "label": {
        "default": "Lasso Paint"
      },
      "minimumSize": {
        "width": 320,
        "height": 240
      },
      "maximumSize": {
        "width": 1600,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 640
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 640
      }
    }
  ]
}